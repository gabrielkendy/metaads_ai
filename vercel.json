{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["gru1"],
  "buildCommand": "pnpm install --frozen-lockfile=false && pnpm build:web",
  "installCommand": "echo 'install via build'",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/cron/meta-sync",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/detect-anomalies",
      "schedule": "0 13 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" }
      ]
    }
  ]
}
