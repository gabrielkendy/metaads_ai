{
  "_comment": "Template — copia para %APPDATA%/Claude/claude_desktop_config.json e troca os placeholders",
  "mcpServers": {
    "base-trafego": {
      "command": "node",
      "args": [
        "C:\\caminho-completo\\base-trafego-command\\apps\\mcp\\dist\\index.js"
      ],
      "env": {
        "SUPABASE_URL": "https://<project-ref>.supabase.co",
        "SUPABASE_SERVICE_ROLE_KEY": "<service-role-key>",
        "SUPABASE_ANON_KEY": "<anon-key>",
        "SUPABASE_ENCRYPTION_KEY": "<32-byte-hex-string>",
        "USE_META_MOCK": "true",
        "META_API_VERSION": "v22.0",
        "PLATFORM_URL": "http://localhost:3000",
        "LOG_LEVEL": "info"
      }
    }
  }
}
