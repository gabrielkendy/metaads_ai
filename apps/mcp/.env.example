# MCP Server — copie para .env e preencha
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
SUPABASE_ENCRYPTION_KEY=generate-32-byte-random-string-here

# Meta API (opcional pro modo dev/mock)
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v22.0
USE_META_MOCK=true

# Anthropic (futuro: usado em tools que invocam Claude SDK)
ANTHROPIC_API_KEY=

# Logs
LOG_LEVEL=info
LOG_PATH=./logs/mcp-server.log

# Plataforma
PLATFORM_URL=http://localhost:3000
PLATFORM_WEBHOOK_SECRET=generate-random
