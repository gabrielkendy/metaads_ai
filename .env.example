# ════════════════════════════════════════════════════════════════════
# BASE TRÁFEGO COMMAND — Environment Variables (template)
# Copie para .env.local e preencha com seus valores reais
# NUNCA COMMIT este arquivo com valores reais
# ════════════════════════════════════════════════════════════════════

# ─── Supabase ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_ENCRYPTION_KEY=generate-32-byte-random-string-here

# ─── Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Meta Marketing API ──────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v22.0
META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback
META_VERIFY_TOKEN=generate-random-string-for-webhook-verification

# ─── Resend (emails) ─────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=command@agenciabase.tech

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── MCP Server ──────────────────────────────────────────────────────
PLATFORM_URL=http://localhost:3000
PLATFORM_WEBHOOK_SECRET=generate-random-secret-here
LOG_LEVEL=info
LOG_PATH=./apps/mcp/logs/mcp-server.log

# ─── Observability (opcional) ────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
