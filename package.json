{
  "name": "base-trafego-command",
  "version": "1.0.0",
  "private": true,
  "description": "BASE Tráfego Command — mini-SaaS multi-tenant de gestão de Meta Ads operado pelo Claude Desktop via MCP",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@base-trafego/web",
    "dev:mcp": "turbo dev --filter=@base-trafego/mcp",
    "build": "turbo build",
    "build:web": "turbo build --filter=@base-trafego/web",
    "build:mcp": "turbo build --filter=@base-trafego/mcp",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID --schema public > apps/web/src/types/database.ts",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:seed": "tsx scripts/seed.ts",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
